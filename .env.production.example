# Base de données — URL de connexion directe Supabase (port 5432, pas le pooler)
# Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[MOT-DE-PASSE]@db.[PROJECT-REF].supabase.co:5432/postgres

# Clé de chiffrement des sessions JWT
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=

# URL publique de l'application en production
NEXTAUTH_URL=https://[ton-projet].vercel.app
