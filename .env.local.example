# Base de données — URL de connexion Supabase (développement)
# Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[MOT-DE-PASSE]@db.[PROJECT-REF].supabase.co:5432/postgres

# Clé de chiffrement des sessions JWT
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=

# URL locale de l'application
NEXTAUTH_URL=http://localhost:3000
